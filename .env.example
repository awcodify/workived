# Server
PORT=8080
ENV=development  # development | staging | production

# Database
DATABASE_URL=postgres://workived:password@localhost:5432/workived?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate a strong random secret for production
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Storage (MinIO for local dev, AWS S3 for production)
S3_BUCKET=workived-files
S3_REGION=ap-southeast-1
S3_ENDPOINT=localhost:9000  # MinIO local endpoint (no protocol!). Leave empty for AWS S3.
S3_USE_SSL=false  # false for local MinIO (http), true for production (https)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Email (mailcatcher for local dev, SMTP for production)
SMTP_HOST=localhost  # Use 'localhost' for mailcatcher, or your SMTP provider host in production
SMTP_PORT=1025  # mailcatcher port. Use 587 or 465 for production SMTP.
SMTP_USER=  # Leave empty for mailcatcher. Set to your SMTP username in production.
SMTP_PASS=  # Leave empty for mailcatcher. Set to your SMTP password in production.
EMAIL_FROM=noreply@workived.com  # Sender email address

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
