# Workived Production Environment Variables
# Copy this file to .env.production and fill in the values

# ============================================
# Server Configuration
# ============================================
PORT=8080
ENV=production

# ============================================
# Database (Supabase or managed PostgreSQL)
# ============================================
# For Supabase, use the pooler connection string (port 6543)
# Example: postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgres://user:password@host:6543/database?sslmode=require

# ============================================
# Redis (local on VPS)
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Authentication
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_32_BYTES_OR_MORE
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ============================================
# Storage (Cloudflare R2 or AWS S3)
# ============================================
S3_BUCKET=workived-files-production
S3_REGION=auto

# For Cloudflare R2:
S3_ENDPOINT=https://[account-id].r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key

# For AWS S3 (remove S3_ENDPOINT):
# S3_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ============================================
# Email (Amazon SES recommended)
# ============================================
# For SES Singapore region
SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-username
SMTP_PASS=your-ses-smtp-password
EMAIL_FROM=noreply@workived.com

# Alternative: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# ============================================
# Application URLs
# ============================================
# Adjust based on your deployment region
APP_URL=https://app.workived.com
API_URL=https://api.workived.com

# For UAE region:
# APP_URL=https://app-uae.workived.com
# API_URL=https://api-uae.workived.com

# ============================================
# Optional: Monitoring & Error Tracking
# ============================================
# SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[project]
# SENTRY_ENVIRONMENT=production
